                                <div id="b2bUpsell_feature_div" class="celwidget" data-feature-name="b2bUpsell"
                 data-csa-c-type="widget" data-csa-c-content-id="b2bUpsell"
                 data-csa-c-slot-id="b2bUpsell_feature_div" data-csa-c-asin="B0C74XYKYR"
